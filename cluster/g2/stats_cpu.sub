#!/bin/bash
#SBATCH -J bg_stats
#SBATCH -o bg_stats_%j.out
#SBATCH -e bg_stats_%j.err
#SBATCH -N 1
#SBATCH -n 16
#SBATCH --mem=64G
#SBATCH -t 4:00:00
#SBATCH --partition=pierson
#SBATCH --get-user-env

set -euo pipefail

: "${PROJECT_DIR:?Set PROJECT_DIR to the backgammon-analysis repo path}"
: "${BG_DATA_DIR:?Set BG_DATA_DIR to shared/scratch data directory}"
: "${CONDA_ENV:?Set CONDA_ENV to the conda env path or name}"

source "$(conda info --base)/etc/profile.d/conda.sh"
conda activate "$CONDA_ENV"

cd "$PROJECT_DIR"

python scripts/trajectory_stats.py \
  --data "$BG_DATA_DIR/artifacts/trajectories/checker_decisions_compact_full.jsonl" \
  --num-workers "${SLURM_CPUS_ON_NODE:-16}" \
  --chunk-size 5000 \
  --progress-every 100000
