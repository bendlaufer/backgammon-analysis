# Copy to cluster/unicorn/unicorn.env and fill with real local values.
# The filled .env file is ignored by git.

export PROJECT_DIR=/home/<YOUR_NETID>/backgammon-analysis
export BG_DATA_DIR=/share/<DATASERVER>/<PROJECT_FOLDER>/backgammon
export CONDA_BASE=/share/apps/software/anaconda3
export CONDA_ENV=/share/<DATASERVER>/<PROJECT_FOLDER>/conda_envs/<YOUR_NETID>_backgammon
export TMPDIR=/home/<YOUR_NETID>/tmp
export UNICORN_PARTITION=default_partition
